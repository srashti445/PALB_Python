class Solution:
    def minParentheses(self, s):
        # code here
        open_brackets = 0
        add = 0
        
        for ch in s:
            if ch == '(':
                open_brackets +=1
            else:  # ch == ')'
                if open_brackets > 0:
                    open_brackets -= 1
                else:
                    add += 1
                    
        return open_brackets + add
        
